<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Sample LaunchAgent for auto-starting DocToPDF at login.

  EDIT THE TWO ABSOLUTE PATHS BELOW to match your machine:
    * ProgramArguments[0]  -> <project>/.venv/bin/python
    * WorkingDirectory     -> <project>
        Required so `python -m doctopdf.app` can import the doctopdf package
        (it runs from source, not an installed wheel). The app finds
        client_secret.json / token.json from the package location regardless,
        but launching from the project dir keeps everything consistent.

  Then:
    mkdir -p ~/Library/LaunchAgents
    cp launchd/com.doctopdf.agent.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.doctopdf.agent.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.doctopdf.agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/ABSOLUTE/PATH/TO/doctopdf/.venv/bin/python</string>
        <string>-m</string>
        <string>doctopdf.app</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/ABSOLUTE/PATH/TO/doctopdf</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/tmp/doctopdf.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/doctopdf.err.log</string>
</dict>
</plist>
